{
  "name": "sign_offs",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "pr_id", "type": "UUID", "required": true,
      "foreign_key": { "references": "pull_requests.id" } },
    { "name": "decision", "type": "ENUM", "required": true,
      "options": ["approved", "changes_requested"] },
    { "name": "approver", "type": "TEXT", "required": true, "max_length": 200 },
    { "name": "note", "type": "TEXT" },
    { "name": "score_at_signoff", "type": "INTEGER" },
    { "name": "open_criticals", "type": "INTEGER", "default": 0 },
    { "name": "decided_at", "type": "DATETIME" }
  ],
  "config": {}
}
