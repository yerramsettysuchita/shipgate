{
  "name": "run_checklist",
  "description": "Run the 7 deterministic definition-of-done checks for a PR, write one checklist_results row per check, and turn every failure into a function-source risk_flag. Sets status=evaluating and clears prior checklist/flags first.",
  "type": "API",
  "visibility": "POD",
  "code": { "$file": "code.py" },
  "permissions": { "grants": [
    { "resource_type": "datastore_table", "resource_name": "pull_requests",
      "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
    { "resource_type": "datastore_table", "resource_name": "checklist_results",
      "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
    { "resource_type": "datastore_table", "resource_name": "risk_flags",
      "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] }
  ] }
}
